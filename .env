# RK3566 Monitor – environment variables
HOST=0.0.0.0
PORT=5000
SECRET_KEY=change-me-in-production
FLASK_ENV=production
LOG_LEVEL=INFO
# Path for the local CSV log file that records graph values.
# When running via Docker Compose the recommended path is /data/metrics_log.csv
# so that the file is written to the mounted ./data volume.
METRICS_LOG_FILE=metrics_log.csv
# How often (in seconds) metrics are collected and broadcast to clients.
POLL_INTERVAL_SECONDS=10
# How many days of data to retain in the local CSV log (older rows are pruned).
RETENTION_DAYS=14
# After this many hours, high-frequency rows in the CSV log are resampled
# (averaged) into 1-minute buckets to reduce file size.
RESAMPLE_AFTER_HOURS=24
# Path to the sysfs/debugfs file used to read NPU load.
# Defaults to the rknpu2 kernel driver debug interface. Override if your
# board exposes NPU utilisation at a different path.
NPU_LOAD_PATH=/sys/kernel/debug/rknpu/load